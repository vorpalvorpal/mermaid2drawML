\name{print.mermaid_graph}
\alias{print.mermaid_graph}
\title{Print a mermaid_graph object}
\usage{
\method{print}{mermaid_graph}(x, ...)
}
\arguments{
\item{x}{A \code{mermaid_graph} object.}

\item{...}{Ignored.}
}
\value{
\code{x}, invisibly.
}
\description{
Prints a compact summary of a \code{mermaid_graph} object showing the
direction, number of nodes, edges, subgraphs, and classes.
}
