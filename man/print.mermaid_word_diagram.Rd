\name{print.mermaid_word_diagram}
\alias{print.mermaid_word_diagram}
\title{Print a mermaid_word_diagram object}
\usage{
\method{print}{mermaid_word_diagram}(x, ...)
}
\arguments{
\item{x}{A \code{mermaid_word_diagram} object.}

\item{...}{Ignored.}
}
\value{
\code{x}, invisibly.
}
\description{
Prints a compact summary of a \code{mermaid_word_diagram} object showing the
number of nodes, edges, subgraphs, direction, and shape ID range.
}
